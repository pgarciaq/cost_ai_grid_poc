meta {
  name: Quota Status
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/v1/quotas/:tenantId
  body: none
  auth: none
}

params:path {
  tenantId: tenant-acme
}

docs {
  ## Quota Status

  Returns quota consumption and threshold alerts for a tenant.

  ### Path Parameters

  **tenantId**: `tenant-acme` | `tenant-globex` | `tenant-initech` | `shared`

  ### Response

  Returns per-meter quotas with consumption %, threshold checks (50/70/90/100%), and fired alerts.
}
