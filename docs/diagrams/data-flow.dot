// Data Flow: Events → Tables → Workers → Outputs
// Shows how data moves through the cost-event-consumer pipeline.
//
// Source: cmd/consumer/main.go (goroutine wiring)
// Tables: internal/inventory/store.go

digraph data_flow {
    graph [
        rankdir=TB
        fontname="Helvetica"
        fontsize=14
        label="Cost Event Consumer — Data Flow"
        labelloc=t
        bgcolor=white
        pad=0.5
        nodesep=0.8
        ranksep=0.9
        compound=true
    ]
    node [fontname="Helvetica" fontsize=10]
    edge [fontname="Helvetica" fontsize=9 color="#555555"]

    // ── External Sources ──
    subgraph cluster_sources {
        label="Event Sources"
        style=filled
        fillcolor="#FAFAFA"
        color="#BDBDBD"
        fontcolor="#616161"
        fontsize=11

        osac [label="OSAC\nfulfillment-service\n(gRPC Watch)" shape=box style="filled,rounded" fillcolor="#E8EAF6" color="#3F51B5"]
        ipp [label="IPP Gateway\n(MaaS inference)\nPOST /api/v1/events" shape=box style="filled,rounded" fillcolor="#F3E5F5" color="#7B1FA2"]
        http_client [label="curl / scripts\nPOST /api/v1/events" shape=box style="filled,rounded" fillcolor="#E0F2F1" color="#009688"]
    }

    // ── Goroutines (Workers) ──
    subgraph cluster_workers {
        label="Goroutines (main binary)"
        style=filled
        fillcolor="#FFF8E1"
        color="#F57F17"
        fontcolor="#F57F17"
        fontsize=11

        watcher [label="watcher\n(continuous)" shape=box style="filled,rounded" fillcolor="#FFE082" color="#F57F17"]
        reconciler [label="reconciler\n(1h interval)" shape=box style="filled,rounded" fillcolor="#FFE082" color="#F57F17"]
        ingest [label="HTTP ingest\n(:8020)" shape=box style="filled,rounded" fillcolor="#FFE082" color="#F57F17"]
        metering [label="metering sweep\n(60s interval)" shape=box style="filled,rounded" fillcolor="#FFCC80" color="#E65100"]
        rating [label="rating sweep\n(30s interval)" shape=box style="filled,rounded" fillcolor="#FFCC80" color="#E65100"]
        kokusync [label="koku-sync\n(2m interval)\n[opt: KOKU_DB_URL]" shape=box style="filled,rounded" fillcolor="#FFE082" color="#F57F17" style="filled,rounded,dashed"]
        splunk_fwd [label="splunk forwarder\n(10s interval)\n[opt: SPLUNK_HEC_URL]" shape=box style="filled,rounded" fillcolor="#FFE082" color="#F57F17" style="filled,rounded,dashed"]
    }

    // ── PostgreSQL Tables ──
    subgraph cluster_db {
        label="PostgreSQL (our DB)"
        style=filled
        fillcolor="#E8F5E9"
        color="#2E7D32"
        fontcolor="#2E7D32"
        fontsize=11

        raw_events [label="raw_events\n(append-only log)" shape=cylinder style=filled fillcolor="#C8E6C9" color="#2E7D32"]

        subgraph cluster_inventory {
            label="Inventory Tables"
            style=filled
            fillcolor="#E8F5E9"
            color="#66BB6A"
            fontsize=9

            inv_ci [label="inventory_\ncompute_instance" shape=cylinder style=filled fillcolor="#A5D6A7" color="#2E7D32"]
            inv_cl [label="inventory_\ncluster" shape=cylinder style=filled fillcolor="#A5D6A7" color="#2E7D32"]
            inv_bm [label="inventory_\nbare_metal" shape=cylinder style=filled fillcolor="#A5D6A7" color="#2E7D32"]
            inv_model [label="inventory_\nmodel" shape=cylinder style=filled fillcolor="#A5D6A7" color="#2E7D32"]
            inv_it [label="inventory_\ninstance_type" shape=cylinder style=filled fillcolor="#A5D6A7" color="#2E7D32"]
        }

        metering_entries [label="metering_entries\n(usage records)" shape=cylinder style=filled fillcolor="#FFF9C4" color="#F57F17"]
        rates [label="rates\n(pricing rules)" shape=cylinder style=filled fillcolor="#E1BEE7" color="#7B1FA2"]
        cost_entries [label="cost_entries\n(metered × rate = $)" shape=cylinder style=filled fillcolor="#FFCDD2" color="#C62828"]
        quotas [label="quotas\n(limits)" shape=cylinder style=filled fillcolor="#B2EBF2" color="#00838F"]
    }

    // ── External Outputs ──
    subgraph cluster_outputs {
        label="Outputs"
        style=filled
        fillcolor="#FAFAFA"
        color="#BDBDBD"
        fontcolor="#616161"
        fontsize=11

        report_api [label="Report API\nGET /api/v1/reports/*" shape=box style="filled,rounded" fillcolor="#E3F2FD" color="#1565C0"]
        balance_api [label="Balance Check API\nGET /customers/.../value" shape=box style="filled,rounded" fillcolor="#E3F2FD" color="#1565C0"]
        koku_db [label="Koku PostgreSQL\nosac_usage_line_items_daily\n(org{id} schema)" shape=cylinder style=filled fillcolor="#F3E5F5" color="#7B1FA2"]
        splunk [label="Splunk HEC\n(audit events)" shape=box style="filled,rounded" fillcolor="#FFECB3" color="#FF8F00"]
        prometheus [label="Prometheus\n:9000/metrics" shape=box style="filled,rounded" fillcolor="#FFF9C4" color="#F57F17"]
    }

    // ══════════════════════════════════
    // Edges — Event Ingestion
    // ══════════════════════════════════

    osac -> watcher [label="Watch stream\n(VM/cluster lifecycle)" color="#3F51B5" fontcolor="#3F51B5"]
    osac -> reconciler [label="List APIs\n(periodic drift check)" color="#3F51B5" fontcolor="#3F51B5" style=dashed]
    ipp -> ingest [label="CloudEvent\n(inference tokens)" color="#7B1FA2" fontcolor="#7B1FA2"]
    http_client -> ingest [label="CloudEvent" color="#009688" fontcolor="#009688"]

    // ══════════════════════════════════
    // Edges — Write to tables
    // ══════════════════════════════════

    watcher -> raw_events [label="store event" color="#2E7D32"]
    watcher -> inv_ci [label="upsert" color="#2E7D32"]
    watcher -> inv_cl [label="upsert" color="#2E7D32"]
    watcher -> inv_bm [label="upsert" color="#2E7D32"]
    watcher -> inv_it [label="upsert" color="#2E7D32"]

    reconciler -> inv_ci [label="upsert" color="#2E7D32" style=dashed]
    reconciler -> inv_cl [label="upsert" color="#2E7D32" style=dashed]
    reconciler -> inv_bm [label="upsert" color="#2E7D32" style=dashed]

    ingest -> raw_events [label="store event" color="#2E7D32"]
    ingest -> inv_model [label="upsert\n(MaaS)" color="#2E7D32"]
    ingest -> metering_entries [label="MaaS meters\n(event-driven)" color="#E65100" fontcolor="#E65100"]

    // ══════════════════════════════════
    // Edges — Workers read/write
    // ══════════════════════════════════

    inv_ci -> metering [label="billable VMs" color="#E65100" fontcolor="#E65100"]
    inv_cl -> metering [label="billable clusters" color="#E65100" fontcolor="#E65100"]
    inv_bm -> metering [label="billable BM" color="#E65100" fontcolor="#E65100"]
    inv_it -> metering [label="cores/mem\nenrichment" color="#E65100" fontcolor="#E65100" style=dashed]
    metering -> metering_entries [label="vm_uptime_seconds\nvm_cpu_core_seconds\ncluster_uptime_seconds\ncluster_worker_node_*\nbm_uptime_seconds" color="#E65100" fontcolor="#E65100"]

    metering_entries -> rating [label="unrated entries\n(rated_at IS NULL)" color="#C62828" fontcolor="#C62828"]
    rates -> rating [label="lookup rate\n(tenant → global)" color="#7B1FA2" fontcolor="#7B1FA2"]
    rating -> cost_entries [label="cost = value × rate" color="#C62828" fontcolor="#C62828"]

    // ══════════════════════════════════
    // Edges — Outputs
    // ══════════════════════════════════

    cost_entries -> report_api [label="GROUP BY\ntenant/type/meter" color="#1565C0" fontcolor="#1565C0"]
    metering_entries -> balance_api [label="SUM(value)\nvs quota" color="#1565C0" fontcolor="#1565C0"]
    quotas -> balance_api [label="limit" color="#00838F" fontcolor="#00838F" style=dashed]

    cost_entries -> kokusync [label="daily costs\n(excl. MaaS)" color="#7B1FA2" fontcolor="#7B1FA2"]
    kokusync -> koku_db [label="INSERT +\ntrigger Masu" color="#7B1FA2" fontcolor="#7B1FA2"]

    raw_events -> splunk_fwd [label="new events\n(cursor-based)" color="#FF8F00" fontcolor="#FF8F00"]
    splunk_fwd -> splunk [label="HEC POST" color="#FF8F00" fontcolor="#FF8F00"]

    // All goroutines emit metrics
    {watcher metering rating ingest kokusync} -> prometheus [style=dotted color="#BDBDBD" constraint=false]
}
