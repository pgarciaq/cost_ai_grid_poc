// Data Flow: Event Ingestion
// Shows how events enter the system and land in tables.
// Focused view: sources → ingestion goroutines → tables.
//
// Source: cmd/consumer/main.go

digraph data_flow_ingestion {
    graph [
        rankdir=TB
        fontname="Helvetica"
        fontsize=14
        label="Event Ingestion — Sources → Tables"
        labelloc=t
        bgcolor=white
        pad=0.5
        nodesep=0.7
        ranksep=0.8
        compound=true
    ]
    node [fontname="Helvetica" fontsize=10]
    edge [fontname="Helvetica" fontsize=9 color="#555555"]

    // ── Event Sources ──
    subgraph cluster_sources {
        label="Event Sources"
        style=filled
        fillcolor="#FAFAFA"
        color="#BDBDBD"
        fontcolor="#616161"
        fontsize=11

        osac [label="OSAC fulfillment-service\n(gRPC Watch stream + REST List)" shape=box style="filled,rounded" fillcolor="#E8EAF6" color="#3F51B5"]
        ipp [label="IPP Gateway\nexternal-metering plugin\nPOST /api/v1/events" shape=box style="filled,rounded" fillcolor="#F3E5F5" color="#7B1FA2"]
        http_client [label="curl / osac-event-stream.sh\nPOST /api/v1/events" shape=box style="filled,rounded" fillcolor="#E0F2F1" color="#009688"]
    }

    // ── Ingestion Goroutines ──
    subgraph cluster_goroutines {
        label="Ingestion Goroutines"
        style=filled
        fillcolor="#FFF8E1"
        color="#F57F17"
        fontcolor="#F57F17"
        fontsize=11

        watcher [label=<
            <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
                <TR><TD><B>watcher</B></TD></TR>
                <TR><TD><FONT POINT-SIZE="8">continuous · watcher.go</FONT></TD></TR>
                <TR><TD><FONT POINT-SIZE="8">VM/cluster/BM lifecycle → upsert</FONT></TD></TR>
            </TABLE>
        > shape=box style="filled,rounded" fillcolor="#FFE082" color="#F57F17"]

        reconciler [label=<
            <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
                <TR><TD><B>reconciler</B></TD></TR>
                <TR><TD><FONT POINT-SIZE="8">1h interval · reconciler.go</FONT></TD></TR>
                <TR><TD><FONT POINT-SIZE="8">List all resources → drift correction</FONT></TD></TR>
            </TABLE>
        > shape=box style="filled,rounded" fillcolor="#FFE082" color="#F57F17"]

        ingest [label=<
            <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
                <TR><TD><B>HTTP ingest</B></TD></TR>
                <TR><TD><FONT POINT-SIZE="8">:8020 · handler.go</FONT></TD></TR>
                <TR><TD><FONT POINT-SIZE="8">CloudEvents → raw_events + meters</FONT></TD></TR>
            </TABLE>
        > shape=box style="filled,rounded" fillcolor="#FFE082" color="#F57F17"]

        splunk_fwd [label=<
            <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
                <TR><TD><B>splunk forwarder</B></TD></TR>
                <TR><TD><FONT POINT-SIZE="8">10s interval · splunk.go</FONT></TD></TR>
                <TR><TD><FONT POINT-SIZE="8">tail raw_events → Splunk HEC</FONT></TD></TR>
            </TABLE>
        > shape=box style="filled,rounded,dashed" fillcolor="#FFE082" color="#F57F17"]
    }

    // ── Tables ──
    subgraph cluster_tables {
        label="PostgreSQL"
        style=filled
        fillcolor="#E8F5E9"
        color="#2E7D32"
        fontcolor="#2E7D32"
        fontsize=11

        raw_events [label="raw_events\n(append-only log)" shape=cylinder style=filled fillcolor="#C8E6C9" color="#2E7D32"]

        inv_ci [label="inventory_compute_instance" shape=cylinder style=filled fillcolor="#A5D6A7" color="#2E7D32"]
        inv_cl [label="inventory_cluster" shape=cylinder style=filled fillcolor="#A5D6A7" color="#2E7D32"]
        inv_bm [label="inventory_bare_metal" shape=cylinder style=filled fillcolor="#A5D6A7" color="#2E7D32"]
        inv_model [label="inventory_model" shape=cylinder style=filled fillcolor="#A5D6A7" color="#2E7D32"]
        inv_it [label="inventory_instance_type" shape=cylinder style=filled fillcolor="#A5D6A7" color="#2E7D32"]

        metering_entries [label="metering_entries\n(MaaS: event-driven)" shape=cylinder style=filled fillcolor="#FFF9C4" color="#F57F17"]
    }

    // ── Splunk output ──
    splunk [label="Splunk HEC" shape=box style="filled,rounded" fillcolor="#FFECB3" color="#FF8F00"]

    // ══════════════════════════════════
    // Edges — Sources → Goroutines
    // ══════════════════════════════════

    osac -> watcher [label="Watch stream\n(real-time events)" color="#3F51B5" fontcolor="#3F51B5"]
    osac -> reconciler [label="List APIs\n(periodic)" color="#3F51B5" fontcolor="#3F51B5" style=dashed]
    ipp -> ingest [label="CloudEvent\n(inference tokens)" color="#7B1FA2" fontcolor="#7B1FA2"]
    http_client -> ingest [label="CloudEvent\n(any type)" color="#009688" fontcolor="#009688"]

    // ══════════════════════════════════
    // Edges — Goroutines → Tables
    // ══════════════════════════════════

    watcher -> raw_events [label="store" color="#2E7D32"]
    watcher -> inv_ci [label="upsert" color="#2E7D32"]
    watcher -> inv_cl [label="upsert" color="#2E7D32"]
    watcher -> inv_bm [label="upsert" color="#2E7D32"]
    watcher -> inv_it [label="upsert" color="#2E7D32"]

    reconciler -> inv_ci [label="upsert" color="#2E7D32" style=dashed]
    reconciler -> inv_cl [label="upsert" color="#2E7D32" style=dashed]
    reconciler -> inv_bm [label="upsert" color="#2E7D32" style=dashed]

    ingest -> raw_events [label="store" color="#2E7D32"]
    ingest -> inv_model [label="upsert\n(MaaS)" color="#2E7D32"]
    ingest -> metering_entries [label="maas_tokens_in\nmaas_tokens_out\nmaas_requests" color="#E65100" fontcolor="#E65100"]

    // ══════════════════════════════════
    // Edges — Splunk forwarder
    // ══════════════════════════════════

    raw_events -> splunk_fwd [label="cursor-based\ntail" color="#FF8F00" fontcolor="#FF8F00"]
    splunk_fwd -> splunk [label="HEC POST" color="#FF8F00" fontcolor="#FF8F00"]
}
